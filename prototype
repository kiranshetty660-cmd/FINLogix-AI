<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FINLogix AI – Smart Supply Chain Finance Optimizer</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #050a14;
  --surface: #0c1525;
  --surface2: #111d31;
  --surface3: #162039;
  --border: rgba(99,179,237,0.13);
  --border2: rgba(99,179,237,0.22);
  --accent: #3b82f6;
  --accent2: #06b6d4;
  --accent3: #8b5cf6;
  --gold: #f59e0b;
  --green: #10b981;
  --red: #ef4444;
  --orange: #f97316;
  --text: #e2e8f0;
  --text2: #94a3b8;
  --text3: #64748b;
  --gemini: linear-gradient(135deg,#4285f4,#0f9d58,#f4b400,#db4437);
}

*{margin:0;padding:0;box-sizing:border-box;}

body{
  font-family:'DM Sans',sans-serif;
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  overflow-x:hidden;
}

/* Animated background */
body::before{
  content:'';
  position:fixed;
  inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 20% -10%,rgba(59,130,246,0.12) 0%,transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 100%,rgba(139,92,246,0.10) 0%,transparent 60%),
    radial-gradient(ellipse 50% 40% at 50% 50%,rgba(6,182,212,0.05) 0%,transparent 70%);
  pointer-events:none;
  z-index:0;
}

/* ─── LAYOUT ─── */
.app{display:flex;min-height:100vh;position:relative;z-index:1;}

/* ─── SIDEBAR ─── */
.sidebar{
  width:240px;
  background:var(--surface);
  border-right:1px solid var(--border);
  display:flex;
  flex-direction:column;
  position:fixed;
  top:0;left:0;bottom:0;
  z-index:100;
  transition:transform .3s;
}

.logo{
  padding:22px 20px 16px;
  border-bottom:1px solid var(--border);
}
.logo-icon{
  width:38px;height:38px;
  background:linear-gradient(135deg,#3b82f6,#8b5cf6);
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;margin-bottom:10px;
  box-shadow:0 0 20px rgba(59,130,246,0.4);
}
.logo h1{font-family:'Syne',sans-serif;font-size:17px;font-weight:800;color:#fff;letter-spacing:-.3px;}
.logo p{font-size:10.5px;color:var(--text3);margin-top:2px;}

.gemini-badge{
  margin:12px 16px;
  padding:7px 12px;
  background:linear-gradient(135deg,rgba(66,133,244,0.15),rgba(15,157,88,0.10));
  border:1px solid rgba(66,133,244,0.3);
  border-radius:8px;
  display:flex;align-items:center;gap:7px;
  font-size:10.5px;font-weight:500;color:#93c5fd;
}
.gemini-dot{
  width:7px;height:7px;border-radius:50%;
  background:linear-gradient(135deg,#4285f4,#0f9d58);
  animation:pulse 2s infinite;
}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.7;transform:scale(1.3);}}

nav{flex:1;padding:8px 0;overflow-y:auto;}
.nav-section{padding:12px 16px 4px;font-size:9.5px;font-weight:600;color:var(--text3);letter-spacing:1.2px;text-transform:uppercase;}
.nav-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 18px;
  font-size:13px;font-weight:500;color:var(--text2);
  cursor:pointer;border-radius:0;
  transition:all .2s;position:relative;
  border-left:3px solid transparent;
}
.nav-item:hover{background:rgba(59,130,246,0.07);color:var(--text);}
.nav-item.active{
  background:rgba(59,130,246,0.12);
  color:#60a5fa;
  border-left-color:#3b82f6;
}
.nav-item .badge{
  margin-left:auto;
  background:var(--accent);
  color:#fff;font-size:9px;font-weight:700;
  padding:2px 6px;border-radius:10px;
}
.nav-item .icon{font-size:15px;width:18px;text-align:center;}

.sidebar-footer{
  padding:14px 16px;
  border-top:1px solid var(--border);
  font-size:10.5px;color:var(--text3);
}

/* ─── MAIN ─── */
.main{margin-left:240px;flex:1;display:flex;flex-direction:column;}

/* ─── TOPBAR ─── */
.topbar{
  padding:14px 28px;
  background:rgba(5,10,20,0.8);
  backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:50;
}
.topbar-left h2{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;}
.topbar-left p{font-size:12px;color:var(--text2);margin-top:1px;}

.topbar-right{display:flex;align-items:center;gap:12px;}
.topbar-btn{
  padding:7px 14px;border-radius:8px;font-size:12.5px;font-weight:600;
  cursor:pointer;transition:all .2s;border:none;
  display:flex;align-items:center;gap:6px;
}
.btn-ghost{background:var(--surface2);color:var(--text2);border:1px solid var(--border);}
.btn-ghost:hover{border-color:var(--border2);color:var(--text);}
.btn-primary{background:var(--accent);color:#fff;}
.btn-primary:hover{background:#2563eb;box-shadow:0 0 20px rgba(59,130,246,0.4);}
.btn-gemini{
  background:linear-gradient(135deg,#4285f4,#0f9d58);
  color:#fff;border:none;
}
.btn-gemini:hover{box-shadow:0 0 20px rgba(66,133,244,0.5);}

.alert-dot{
  width:8px;height:8px;background:var(--red);border-radius:50%;
  animation:pulse 1.5s infinite;
}

/* ─── PAGE CONTENT ─── */
.page{display:none;padding:24px 28px;animation:fadeIn .3s ease;}
.page.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}

/* ─── CARDS ─── */
.card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:14px;
  padding:20px;
  transition:border-color .2s;
}
.card:hover{border-color:var(--border2);}

.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.card-title{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--text);}
.card-sub{font-size:11px;color:var(--text3);margin-top:2px;}

/* ─── KPI GRID ─── */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
.kpi-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:14px;
  padding:18px 20px;
  position:relative;overflow:hidden;
  transition:all .25s;
}
.kpi-card:hover{transform:translateY(-2px);border-color:var(--border2);}
.kpi-card::before{
  content:'';position:absolute;top:0;right:0;
  width:80px;height:80px;border-radius:50%;
  filter:blur(30px);opacity:.5;
}
.kpi-card.blue::before{background:#3b82f6;}
.kpi-card.green::before{background:#10b981;}
.kpi-card.gold::before{background:#f59e0b;}
.kpi-card.purple::before{background:#8b5cf6;}

.kpi-label{font-size:11px;color:var(--text3);font-weight:500;letter-spacing:.3px;margin-bottom:8px;}
.kpi-value{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;}
.kpi-value.blue{color:#60a5fa;}
.kpi-value.green{color:#34d399;}
.kpi-value.gold{color:#fbbf24;}
.kpi-value.purple{color:#a78bfa;}

.kpi-change{font-size:11px;margin-top:5px;display:flex;align-items:center;gap:4px;}
.kpi-change.up{color:#34d399;}
.kpi-change.down{color:#f87171;}

/* ─── GRID LAYOUTS ─── */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;}
.grid-7-5{display:grid;grid-template-columns:1.4fr 1fr;gap:16px;}

/* ─── RISK TABLE ─── */
.table{width:100%;border-collapse:collapse;}
.table th{
  font-size:10.5px;font-weight:600;color:var(--text3);
  text-transform:uppercase;letter-spacing:.8px;
  padding:10px 14px;text-align:left;
  border-bottom:1px solid var(--border);
}
.table td{padding:11px 14px;font-size:13px;border-bottom:1px solid rgba(99,179,237,0.06);}
.table tr:last-child td{border-bottom:none;}
.table tr:hover td{background:rgba(59,130,246,0.04);}

.risk-badge{
  display:inline-flex;align-items:center;gap:5px;
  padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;
}
.risk-high{background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25);}
.risk-medium{background:rgba(249,115,22,.15);color:#fb923c;border:1px solid rgba(249,115,22,.25);}
.risk-low{background:rgba(16,185,129,.15);color:#34d399;border:1px solid rgba(16,185,129,.25);}

.action-btn{
  padding:4px 10px;border-radius:6px;font-size:11px;font-weight:600;
  cursor:pointer;border:none;transition:all .2s;
}
.action-btn.blue{background:rgba(59,130,246,.15);color:#60a5fa;}
.action-btn.blue:hover{background:rgba(59,130,246,.3);}

/* ─── PROGRESS BARS ─── */
.progress-bar{height:6px;background:var(--surface3);border-radius:3px;overflow:hidden;margin-top:4px;}
.progress-fill{height:100%;border-radius:3px;transition:width .8s ease;}

/* ─── WHAT-IF SIMULATOR ─── */
.simulator-card{
  background:linear-gradient(135deg,rgba(59,130,246,0.08),rgba(139,92,246,0.06));
  border:1px solid rgba(59,130,246,0.25);
  border-radius:14px;padding:20px;
}
.sim-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.sim-label{font-size:12.5px;color:var(--text2);font-weight:500;}
.sim-val{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;color:#60a5fa;}

input[type=range]{
  -webkit-appearance:none;
  width:100%;height:4px;background:var(--surface3);border-radius:2px;outline:none;margin:8px 0;
}
input[type=range]::-webkit-slider-thumb{
  -webkit-appearance:none;width:16px;height:16px;
  background:var(--accent);border-radius:50%;cursor:pointer;
  box-shadow:0 0 8px rgba(59,130,246,0.5);
}

.sim-result{
  background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.25);
  border-radius:10px;padding:14px;margin-top:12px;
}
.sim-result-main{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:#34d399;}
.sim-result-label{font-size:11px;color:var(--text2);margin-top:3px;}

/* ─── CHAT ─── */
.chat-container{display:flex;flex-direction:column;height:520px;}
.chat-messages{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:14px;}
.chat-messages::-webkit-scrollbar{width:4px;}
.chat-messages::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:2px;}

.msg{display:flex;gap:10px;max-width:88%;}
.msg.user{flex-direction:row-reverse;align-self:flex-end;}
.msg-avatar{
  width:32px;height:32px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:14px;
}
.msg-avatar.ai{background:linear-gradient(135deg,#4285f4,#0f9d58);}
.msg-avatar.user-av{background:linear-gradient(135deg,#8b5cf6,#3b82f6);}
.msg-bubble{
  padding:11px 14px;border-radius:14px;font-size:13px;line-height:1.6;
}
.msg.ai .msg-bubble{background:var(--surface2);border:1px solid var(--border);color:var(--text);}
.msg.user .msg-bubble{background:var(--accent);color:#fff;}

.msg-source{font-size:10px;color:var(--text3);margin-top:5px;display:flex;align-items:center;gap:4px;}

.chat-input-area{
  padding:14px;border-top:1px solid var(--border);
  display:flex;gap:10px;align-items:flex-end;
}
.chat-input{
  flex:1;background:var(--surface2);border:1px solid var(--border);
  border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;
  font-family:'DM Sans',sans-serif;resize:none;outline:none;
  transition:border-color .2s;
}
.chat-input:focus{border-color:var(--border2);}
.chat-send{
  width:38px;height:38px;background:var(--accent);border-radius:10px;
  display:flex;align-items:center;justify-content:center;cursor:pointer;border:none;
  font-size:16px;transition:all .2s;flex-shrink:0;
}
.chat-send:hover{background:#2563eb;box-shadow:0 0 15px rgba(59,130,246,0.4);}

.suggested-chips{display:flex;flex-wrap:wrap;gap:7px;padding:10px 14px 0;}
.chip{
  padding:5px 12px;background:var(--surface2);border:1px solid var(--border);
  border-radius:20px;font-size:11.5px;color:var(--text2);cursor:pointer;
  transition:all .2s;
}
.chip:hover{border-color:var(--accent);color:#60a5fa;background:rgba(59,130,246,0.08);}

/* ─── EXPLAINABLE AI ─── */
.xai-bar{margin-bottom:10px;}
.xai-label{display:flex;justify-content:space-between;font-size:12px;color:var(--text2);margin-bottom:4px;}
.xai-fill{height:8px;border-radius:4px;}

/* ─── OPTIMIZATION ─── */
.opt-card{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:12px;padding:16px;
  display:flex;align-items:flex-start;gap:14px;
}
.opt-icon{
  width:38px;height:38px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;
}
.opt-priority{
  display:inline-flex;align-items:center;gap:4px;
  padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700;
  margin-top:6px;
}
.priority-high{background:rgba(239,68,68,.12);color:#f87171;}
.priority-med{background:rgba(249,115,22,.12);color:#fb923c;}
.priority-low{background:rgba(16,185,129,.12);color:#34d399;}

/* ─── UPLOAD ─── */
.upload-zone{
  border:2px dashed var(--border2);border-radius:14px;
  padding:40px 20px;text-align:center;cursor:pointer;
  transition:all .3s;
  background:rgba(59,130,246,0.03);
}
.upload-zone:hover{border-color:#3b82f6;background:rgba(59,130,246,0.06);}
.upload-icon{font-size:40px;margin-bottom:14px;}
.upload-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;margin-bottom:6px;}

.sample-data-box{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:10px;padding:14px;margin-top:14px;
}
.sample-row{
  display:flex;font-size:11.5px;padding:5px 0;
  border-bottom:1px solid var(--border);color:var(--text2);
}
.sample-row:last-child{border-bottom:none;}
.sample-col{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.sample-row.header{color:var(--accent2);font-weight:600;font-size:10.5px;}

/* ─── REPORTS ─── */
.report-card{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:12px;padding:18px;
  display:flex;align-items:center;justify-content:space-between;
  transition:all .2s;cursor:pointer;
}
.report-card:hover{border-color:var(--border2);background:var(--surface3);}
.report-icon{font-size:24px;margin-right:14px;}
.report-meta{font-size:11px;color:var(--text3);margin-top:3px;}
.report-size{font-size:11px;color:var(--text3);}

/* ─── INSIGHT CARDS ─── */
.insight-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.insight-card{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:12px;padding:16px;
}
.insight-header{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
.insight-icon{
  width:30px;height:30px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;font-size:14px;
}
.insight-title{font-size:13px;font-weight:600;}
.insight-number{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;margin-bottom:4px;}
.insight-desc{font-size:12px;color:var(--text2);line-height:1.5;}

/* ─── MINI CHART (CSS only) ─── */
.sparkline{display:flex;align-items:flex-end;gap:3px;height:40px;padding-top:8px;}
.spark-bar{
  flex:1;border-radius:2px 2px 0 0;
  background:linear-gradient(to top,rgba(59,130,246,0.3),rgba(59,130,246,0.7));
  min-height:4px;transition:all .3s;
}
.spark-bar:hover{background:var(--accent);}

/* ─── DONUT (CSS trick) ─── */
.donut-wrap{position:relative;width:100px;height:100px;flex-shrink:0;}
.donut{width:100px;height:100px;border-radius:50%;}
.donut-center{
  position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
}
.donut-pct{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;}
.donut-sub{font-size:9px;color:var(--text3);}

/* ─── SCORE CIRCLE ─── */
.score-circle{
  width:80px;height:80px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;flex-direction:column;
  border:3px solid;flex-shrink:0;
}
.score-num{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;}
.score-lbl{font-size:8.5px;color:var(--text3);}

/* ─── TOAST ─── */
.toast{
  position:fixed;bottom:24px;right:24px;z-index:999;
  background:var(--surface2);border:1px solid var(--green);
  border-radius:12px;padding:14px 18px;
  display:flex;align-items:center;gap:10px;
  font-size:13px;max-width:300px;
  transform:translateY(100px);opacity:0;
  transition:all .4s;box-shadow:0 8px 24px rgba(0,0,0,0.4);
}
.toast.show{transform:none;opacity:1;}
.toast-icon{font-size:18px;}

/* ─── AI THINKING ─── */
.thinking{display:flex;gap:4px;align-items:center;padding:4px 0;}
.thinking span{width:6px;height:6px;background:#60a5fa;border-radius:50%;animation:bounce .8s infinite;}
.thinking span:nth-child(2){animation-delay:.15s;}
.thinking span:nth-child(3){animation-delay:.3s;}
@keyframes bounce{0%,100%{transform:translateY(0);}50%{transform:translateY(-5px);}}

/* ─── HEADER BANNER ─── */
.hero-banner{
  background:linear-gradient(135deg,rgba(59,130,246,0.12),rgba(139,92,246,0.08));
  border:1px solid rgba(59,130,246,0.2);
  border-radius:16px;padding:20px 24px;margin-bottom:20px;
  display:flex;align-items:center;justify-content:space-between;
}
.hero-title{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;}
.hero-sub{font-size:13px;color:var(--text2);margin-top:4px;max-width:500px;line-height:1.5;}
.hero-stats{display:flex;gap:24px;}
.hero-stat-val{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:#34d399;}
.hero-stat-lbl{font-size:10px;color:var(--text3);}

/* ─── MISC ─── */
.divider{height:1px;background:var(--border);margin:16px 0;}
.tag{
  display:inline-flex;align-items:center;gap:4px;
  padding:2px 8px;border-radius:10px;font-size:10.5px;font-weight:600;
}
.tag-blue{background:rgba(59,130,246,.12);color:#60a5fa;}
.tag-green{background:rgba(16,185,129,.12);color:#34d399;}
.tag-gold{background:rgba(245,158,11,.12);color:#fbbf24;}

.section-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;margin-bottom:14px;color:var(--text);}

.powered-by{
  display:inline-flex;align-items:center;gap:6px;
  padding:5px 12px;border-radius:20px;
  background:linear-gradient(135deg,rgba(66,133,244,0.12),rgba(15,157,88,0.08));
  border:1px solid rgba(66,133,244,0.25);
  font-size:11px;font-weight:600;color:#93c5fd;
}

.loading-bar{
  height:3px;background:var(--surface3);border-radius:2px;overflow:hidden;
}
.loading-fill{
  height:100%;width:0;
  background:linear-gradient(90deg,#3b82f6,#8b5cf6);
  border-radius:2px;
  animation:load 2.5s ease forwards;
}
@keyframes load{to{width:100%;}}

/* ─── CASHFLOW CHART (CSS bars) ─── */
.cf-chart{display:flex;align-items:flex-end;gap:8px;height:120px;padding-bottom:4px;}
.cf-group{display:flex;gap:3px;align-items:flex-end;flex:1;}
.cf-bar{
  flex:1;border-radius:3px 3px 0 0;min-height:4px;
  position:relative;cursor:pointer;transition:opacity .2s;
}
.cf-bar:hover{opacity:.8;}
.cf-in{background:linear-gradient(to top,rgba(16,185,129,0.5),rgba(16,185,129,0.9));}
.cf-out{background:linear-gradient(to top,rgba(239,68,68,0.4),rgba(239,68,68,0.8));}
.cf-labels{display:flex;gap:8px;padding-top:6px;}
